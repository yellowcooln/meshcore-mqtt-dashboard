# Web UI / HTTP
WEB_PORT=8081
DASH_TITLE=MQTT Observatory

# MQTT broker connection
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_TRANSPORT=tcp
MQTT_WS_PATH=/mqtt
MQTT_TLS=false
MQTT_TLS_INSECURE=false
MQTT_CA_CERT=

# MQTT subscriptions and node activity
# Multiple topics can be comma-separated, e.g. "meshcore/BOS/#,meshcore/NYC/#".
MQTT_TOPIC=meshcore/#
MQTT_SYS_TOPIC=$$SYS/#
SYS_TOPICS_ENABLED=true
MQTT_ONLINE_SECONDS=300
NODE_PURGE_SECONDS=600
SYS_TOPICS_LIMIT=200

# Dashboard API protection (/snapshot, /stats, /packets)
DASH_API_TOKEN=
DASH_API_TOKEN_HEADER=X-Dashboard-Token

# MQTT ingress authentication (optional)
MQTT_AUTH_TOKEN=
MQTT_AUTH_TOKEN_HEADER=Authorization
MQTT_AUTH_TOKEN_SCHEME=Bearer

# Packet storage and metrics
PACKET_DB_PATH=/data/packets.db
PACKET_RETENTION_SECONDS=7200
STATS_WINDOW_SECONDS=60
ROLE_OVERRIDES_FILE=/data/device_roles.json
